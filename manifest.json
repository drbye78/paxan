{
  "manifest_version": 3,
  "name": "ProxyMania VPN",
  "version": "2.2.0",
  "description": "Free VPN service using ProxyMania proxy servers",
  "permissions": [
    "proxy",
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://proxymania.su/*",
    "https://httpbin.org/*",
    "https://www.google.com/*",
    "https://connectivitycheck.gstatic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ProxyMania VPN"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/modules/webrtc-blocker.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
