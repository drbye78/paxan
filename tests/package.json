{
  "name": "proxymania-vpn-tests",
  "version": "2.3.0",
  "description": "Comprehensive test suite for ProxyMania VPN Chrome extension",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "playwright test",
    "test:performance": "jest tests/performance",
    "test:security": "jest tests/security",
    "test:accessibility": "playwright test tests/accessibility",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "security:audit": "npm audit",
    "security:scan": "npm audit --audit-level=moderate",
    "performance:audit": "lighthouse-ci autorun",
    "playwright:install": "npx playwright install",
    "playwright:install-deps": "npx playwright install-deps",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:debug": "jest --debug",
    "test:verbose": "jest --verbose",
    "test:clear-cache": "jest --clearCache"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.8",
    "babel-jest": "^29.7.0",
    "eslint": "^8.54.0",
    "eslint-plugin-jest": "^27.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "playwright": "^1.40.0",
    "supertest": "^6.3.3"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es6": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error",
      "no-var": "error"
    },
    "overrides": [
      {
        "files": [
          "**/*.test.js"
        ],
        "env": {
          "jest": true
        },
        "rules": {
          "no-console": "off"
        }
      }
    ]
  },
  "jest-junit": {
    "outputDirectory": "./test-results",
    "outputName": "junit.xml",
    "suiteName": "ProxyMania VPN Tests",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}",
    "ancestorSeparator": " › ",
    "usePathForSuiteName": true
  },
  "lighthouse-ci": {
    "ci": {
      "collect": {
        "url": [
          "http://localhost:3000"
        ],
        "startServerCommand": "npm start",
        "startServerReadyPattern": "ready",
        "startServerReadyTimeout": 30000
      },
      "assert": {
        "assertions": {
          "categories:performance": [
            "error",
            {
              "minScore": 0.8
            }
          ],
          "categories:accessibility": [
            "error",
            {
              "minScore": 0.9
            }
          ],
          "categories:best-practices": [
            "error",
            {
              "minScore": 0.8
            }
          ],
          "categories:seo": [
            "error",
            {
              "minScore": 0.8
            }
          ]
        }
      },
      "upload": {
        "target": "temporary-public-storage"
      }
    }
  }
}
